# Supabase (required for auth, database, storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for admin storage uploads (project media) and server-side RLS bypass
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (email notifications: membership request → admin, approval → member)
RESEND_API_KEY=re_xxxxx

# Email addresses (optional; defaults shown)
EMAIL_FROM=Crestline Capital <onboarding@resend.dev>
ADMIN_EMAIL=admin@crestlinecapital.in
EMAIL_TO=admin@crestlinecapital.in

# Optional: canonical site URL (for OpenGraph and metadata)
NEXT_PUBLIC_SITE_URL=https://crestlinecapital.in

# Optional: enable Phone OTP in Supabase Dashboard > Authentication > Providers > Phone
# Configure an SMS provider (Twilio, MessageBird, etc.) in Supabase for OTP delivery.
